generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum Language {
  JAVASCRIPT
  TYPESCRIPT
  PYTHON
  JAVA
  CPP
}

enum SubmissionStatus {
  QUEUED
  PROCESSING
  SUCCESS
  COMPILATION_ERROR
  RUNTIME_ERROR
  TIME_LIMIT_EXCEEDED
  MEMORY_LIMIT_EXCEEDED
  INTERNAL_ERROR
  CANCELLED
}

model Submission {
  id     String  @id @default(uuid())
  userId String?

  language Language
  code     String   @db.Text

  status SubmissionStatus @default(QUEUED)

  output        String? @db.Text
  stderr        String? @db.Text
  compileOutput String? @db.Text

  exitCode        Int?
  executionTimeMs Int?
  memoryUsedKb    Int?

  createdAt  DateTime  @default(now())
  startedAt  DateTime?
  finishedAt DateTime?
  updatedAt  DateTime  @updatedAt

  @@index([status])
  @@index([userId])
  @@index([createdAt])
}
